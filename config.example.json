{
  "plugins": {
    "enabled": true,
    "allow": [
      "telegram"
    ],
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allowFrom": [
        "YOUR_TELEGRAM_USER_ID"
      ]
    }
  },
  "providers": {
    "custom": [
      {
        "apiKey": "YOUR_GEMINI_API_KEY",
        "model": "gemini-3.1-pro-preview",
        "apiBase": "https://generativelanguage.googleapis.com/v1beta/openai"
      }
    ]
  },
  "agents": {
    "defaults": {
      "model": "gemini-3.1-pro-preview",
      "temperature": 0.7,
      "maxTokens": 4096
    }
  }
}
